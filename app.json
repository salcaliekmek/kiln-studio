{
  "expo": {
    "name": "Kilnly",
    "slug": "onni-studio",
    "scheme": "onni-studio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#F8F5F1"
    },
    "ios": {
      "bundleIdentifier": "net.onnidesign.studio",
      "buildNumber": "2",
      "supportsTablet": false,
      "infoPlist": {
        "NSUserTrackingUsageDescription": "Bu uygulama kullanıcı takibi yapmamaktadır.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "net.onnidesign.studio",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F5F1"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-router"
    ],
    "extra": {
      "eas": {
        "projectId": "f707b095-41c3-4fac-b2ad-c346ca5d5fd1"
      },
      "router": {}
    },
    "owner": "ercmntkksl"
  }
}
